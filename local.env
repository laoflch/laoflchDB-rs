# laoflchDB-rust 构建环境变量配置
# 使用方式: source local.env

# clang 编译器路径（用于 bindgen 生成绑定）
export CLANG_PATH=/workspace/cquery/cquery/clang+llvm-7.0.0-x86_64-linux-gnu-ubuntu-14.04/bin/clang
export LIBCLANG_PATH=/workspace/cquery/cquery/clang+llvm-7.0.0-x86_64-linux-gnu-ubuntu-14.04/lib

# 将 clang 添加到 PATH（放在 GCC 之前）
export PATH=/workspace/cquery/cquery/clang+llvm-7.0.0-x86_64-linux-gnu-ubuntu-14.04/bin:$PATH

# GCC 13 编译器路径（支持 C++20）
export PATH=/usr/local/gcc-13/bin:$PATH

# C/C++ 编译器配置（保持 GCC）
export CC=gcc
export CXX=g++

# Rust 工具链配置（可选）
export RUSTFLAGS=""

# 构建目录（可选）
export CARGO_TARGET_DIR=target

# 打印环境信息（可选）
echo "环境变量已设置:"
echo "  CC=$CC"
echo "  CXX=$CXX"
echo "  CLANG_PATH=$CLANG_PATH"
echo "  LIBCLANG_PATH=$LIBCLANG_PATH"
echo "  PATH 包含: /workspace/cquery/cquery/clang+llvm-7.0.0-x86_64-linux-gnu-ubuntu-14.04/bin"
echo "  PATH 包含: /usr/local/gcc-13/bin"